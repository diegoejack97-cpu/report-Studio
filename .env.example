# ════════════════════════════════════════════════
# Report Studio — Environment Configuration
# Copy this file to .env and fill in your values
# ════════════════════════════════════════════════

# ── App ───────────────────────────────────────
ENVIRONMENT=development
APP_URL=http://localhost
VITE_API_URL=http://localhost:8000

# ── Security ──────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=change_me_generate_with_openssl_rand_hex_32

# ── Database ──────────────────────────────────
DB_PASSWORD=rs_secret_change_in_prod

# ── Redis ─────────────────────────────────────
REDIS_PASSWORD=rs_redis_change_in_prod

# ── Stripe (get from dashboard.stripe.com) ────
# Use sk_test_* for dev, sk_live_* for prod
STRIPE_SECRET_KEY=sk_test_your_key_here
STRIPE_PUBLIC_KEY=pk_test_your_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Stripe Price IDs (create in Stripe dashboard)
STRIPE_PRICE_STARTER=price_starter_id_here
STRIPE_PRICE_PRO=price_pro_id_here
STRIPE_PRICE_BUSINESS=price_business_id_here

# ── Email (optional — for password reset) ─────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
EMAIL_FROM=noreply@reportstudio.com
